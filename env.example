require("dotenv").config();

const fs = require("node:fs");
const path = require("node:path");
const {
  ActionRowBuilder,
  AttachmentBuilder,
  ButtonBuilder,
  ButtonStyle,
  ChannelType,
  Client,
  EmbedBuilder,
  Events,
  GatewayIntentBits,
  PermissionFlagsBits,
} = require("discord.js");

const {
  DISCORD_TOKEN,
  WELCOME_CHANNEL_ID,
  VERIFIED_ROLE_ID,
  TICKET_CATEGORY_ID,
  STAFF_ROLE_IDS: STAFF_ROLE_IDS_VALUE = "",
} = process.env;

if (!DISCORD_TOKEN) {
  console.error("Missing DISCORD_TOKEN in .env");
  process.exit(1);
}

const STAFF_ROLE_IDS = STAFF_ROLE_IDS_VALUE
  .split(",")
  .map((roleId) => roleId.trim())
  .filter(Boolean);

const VERIFY_BUTTON_ID = "verify_member";
const HELP_CLAIM_BUTTON_ID = "claim_help";
const TICKET_OPEN_BUTTON_ID = "open_player_report_ticket";
const TICKET_CLAIM_BUTTON_ID = "claim_player_report_ticket";
const TICKET_CLOSE_BUTTON_ID = "close_player_report_ticket";
const VERIFY_IMAGE_PATH = path.join(__dirname, "..", "images (5).jpg");
const ticketClaimLocks = new Set();

const client = new Client({
  intents: [
    GatewayIntentBits.Guilds,
    GatewayIntentBits.GuildMembers,
    GatewayIntentBits.GuildMessages,
    GatewayIntentBits.MessageContent,
    GatewayIntentBits.GuildVoiceStates,
  ],
});

function isStaff(member) {
  return member?.permissions?.has(PermissionFlagsBits.ManageGuild)
    || STAFF_ROLE_IDS.some((roleId) => member?.roles?.cache?.has(roleId));
}

function getTicketOwnerId(channel) {
  return channel.topic?.match(/^player-report-ticket:(\d+)/)?.[1] ?? null;
}

async function replyPrivately(interaction, content) {
  const options = { content, flags: 64 };

  try {
    if (interaction.deferred || interaction.replied) {
      return await interaction.followUp(options);
    }

    return await interaction.reply(options);
  } catch (error) {
    console.error("Could not respond to interaction:", error);
    return null;
  }
}

function buildHelpRequest(member, textChannel, voiceChannel) {
  const embed = new EmbedBuilder()
    .setColor(0xf17100)
    .setTitle("צריך עזרה")
    .setDescription(`${member} צריך עזרה בשיחה ${voiceChannel}.`)
    .addFields(
      { name: "סטטוס", value: "ממתין לצוות" },
      { name: "שיחת קול", value: `${voiceChannel}` },
      { name: "חדר בקשה", value: `${textChannel}` },
    )
    .setTimestamp();

  const row = new ActionRowBuilder().addComponents(
    new ButtonBuilder()
      .setCustomId(HELP_CLAIM_BUTTON_ID)
      .setLabel("לקחת טיפול")
      .setStyle(ButtonStyle.Primary),
  );

  return { embeds: [embed], components: [row] };
}

function buildTicketPanel() {
  const embed = new EmbedBuilder()
    .setColor(0xf17100)
    .setTitle("טיקטים")
    .setDescription("לחץ על הכפתור כדי לפתוח טיקט לדיווח על שחקן.");

  const row = new ActionRowBuilder().addComponents(
    new ButtonBuilder()
      .setCustomId(TICKET_OPEN_BUTTON_ID)
      .setLabel("טיקט לדיווח על שחקן")
      .setStyle(ButtonStyle.Danger),
  );

  return { embeds: [embed], components: [row] };
}

function buildTicketActionRow({ claimedBy } = {}) {
  return new ActionRowBuilder().addComponents(
    new ButtonBuilder()
      .setCustomId(TICKET_CLAIM_BUTTON_ID)
      .setLabel(claimedBy ? `נלקח על ידי ${claimedBy}` : "לקחת טיקט")
      .setStyle(claimedBy ? ButtonStyle.Success : ButtonStyle.Primary)
      .setDisabled(Boolean(claimedBy)),
    new ButtonBuilder()
      .setCustomId(TICKET_CLOSE_BUTTON_ID)
      .setLabel("סגור טיקט")
      .setStyle(ButtonStyle.Secondary),
  );
}

client.once(Events.ClientReady, (readyClient) => {
  console.log(`Logged in as ${readyClient.user.tag}`);
});

client.on(Events.Error, (error) => {
  console.error("Discord client error:", error);
});

process.on("unhandledRejection", (error) => {
  console.error("Unhandled promise rejection:", error);
});

client.on(Events.GuildMemberAdd, async (member) => {
  if (!WELCOME_CHANNEL_ID) return;

  const channel = await member.guild.channels.fetch(WELCOME_CHANNEL_ID).catch(() => null);
  if (!channel?.isTextBased()) return;

  const embed = new EmbedBuilder()
    .setColor(0x2ecc71)
    .setTitle("ברוכים הבאים!")
    .setDescription(`היי ${member}, ברוך הבא ל־**${member.guild.name}**.`)
    .setThumbnail(member.user.displayAvatarURL({ size: 128 }))
    .setTimestamp();

  await channel.send({ embeds: [embed] }).catch(console.error);
});

client.on(Events.MessageCreate, async (message) => {
  if (message.author.bot || message.content.toLowerCase() !== "!help") return;

  const voiceChannel = message.member?.voice?.channel;
  if (!voiceChannel) {
    await message.reply("אתה צריך להיות בשיחת קול כדי להשתמש ב־`!help`.").catch(console.error);
    return;
  }

  await message.reply(buildHelpRequest(message.member, message.channel, voiceChannel)).catch(console.error);
});

client.on(Events.InteractionCreate, async (interaction) => {
  try {
    if (interaction.isChatInputCommand() && interaction.commandName === "help") {
      const voiceChannel = interaction.member?.voice?.channel;
      if (!voiceChannel) {
        await replyPrivately(interaction, "אתה צריך להיות בשיחת קול כדי להשתמש בפקודה הזאת.");
        return;
      }

      await interaction.channel.send(buildHelpRequest(interaction.member, interaction.channel, voiceChannel));
      await replyPrivately(interaction, "הבקשה נשלחה לצוות.");
      return;
    }

    if (interaction.isChatInputCommand() && interaction.commandName === "setup-ticket") {
      if (!interaction.memberPermissions?.has(PermissionFlagsBits.ManageGuild)) {
        await replyPrivately(interaction, "נדרשת הרשאת ניהול שרת כדי להשתמש בפקודה.");
        return;
      }

      if (!TICKET_CATEGORY_ID) {
        await replyPrivately(interaction, "מערכת הטיקטים עדיין לא הוגדרה. חסר TICKET_CATEGORY_ID.");
        return;
      }

      await interaction.channel.send(buildTicketPanel());
      await replyPrivately(interaction, "פאנל הטיקטים נשלח.");
      return;
    }

    if (interaction.isChatInputCommand() && interaction.commandName === "setup-verify") {
      if (!interaction.memberPermissions?.has(PermissionFlagsBits.ManageGuild)) {
        await replyPrivately(interaction, "נדרשת הרשאת ניהול שרת כדי להשתמש בפקודה.");
        return;
      }

      const embed = new EmbedBuilder()
        .setColor(0xf17100)
        .setDescription("כדי לקבל גישה לשרת, לחצו על כפתור האימות.");
      const payload = {
        embeds: [embed],
        components: [
          new ActionRowBuilder().addComponents(
            new ButtonBuilder()
              .setCustomId(VERIFY_BUTTON_ID)
              .setLabel("אימות")
              .setStyle(ButtonStyle.Success),
          ),
        ],
      };

      if (fs.existsSync(VERIFY_IMAGE_PATH)) {
        payload.files = [new AttachmentBuilder(VERIFY_IMAGE_PATH, { name: "verify-banner.jpg" })];
        embed.setImage("attachment://verify-banner.jpg");
      }

      await interaction.channel.send(payload);
      await replyPrivately(interaction, "פאנל האימות נשלח.");
      return;
    }

    if (interaction.isButton() && interaction.customId === TICKET_OPEN_BUTTON_ID) {
      if (!TICKET_CATEGORY_ID) {
        await replyPrivately(interaction, "מערכת הטיקטים עדיין לא הוגדרה.");
        return;
      }

      const category = await interaction.guild.channels.fetch(TICKET_CATEGORY_ID).catch(() => null);
      if (!category || category.type !== ChannelType.GuildCategory) {
        await replyPrivately(interaction, "קטגוריית הטיקטים שהוגדרה לא קיימת בשרת הזה.");
        return;
      }

      const channels = await interaction.guild.channels.fetch();
      const existingTicket = channels.find((channel) => (
        channel?.parentId === TICKET_CATEGORY_ID
        && channel.topic === `player-report-ticket:${interaction.user.id}`
      ));

      if (existingTicket) {
        await replyPrivately(interaction, `כבר יש לך טיקט פתוח: ${existingTicket}`);
        return;
      }

      const roles = await interaction.guild.roles.fetch();
      const validStaffRoleIds = STAFF_ROLE_IDS.filter((roleId) => roles.has(roleId));
      const permissionOverwrites = [
        { id: interaction.guild.id, deny: [PermissionFlagsBits.ViewChannel] },
        {
          id: interaction.user.id,
          allow: [
            PermissionFlagsBits.ViewChannel,
            PermissionFlagsBits.SendMessages,
            PermissionFlagsBits.ReadMessageHistory,
          ],
        },
        {
          id: client.user.id,
          allow: [
            PermissionFlagsBits.ViewChannel,
            PermissionFlagsBits.SendMessages,
            PermissionFlagsBits.ManageChannels,
            PermissionFlagsBits.ReadMessageHistory,
          ],
        },
        ...validStaffRoleIds.map((roleId) => ({
          id: roleId,
          allow: [
            PermissionFlagsBits.ViewChannel,
            PermissionFlagsBits.SendMessages,
            PermissionFlagsBits.ReadMessageHistory,
          ],
        })),
      ];

      await interaction.deferReply({ flags: 64 });
      const safeUsername = interaction.user.username
        .toLowerCase()
        .replace(/[^a-z0-9-]/g, "-")
        .replace(/-+/g, "-")
        .replace(/^-|-$/g, "")
        .slice(0, 50);

      const ticketChannel = await interaction.guild.channels.create({
        name: `report-${safeUsername || interaction.user.id}`,
        type: ChannelType.GuildText,
        parent: TICKET_CATEGORY_ID,
        topic: `player-report-ticket:${interaction.user.id}`,
        permissionOverwrites,
      });

      const embed = new EmbedBuilder()
        .setColor(0xf17100)
        .setTitle("טיקט לדיווח על שחקן")
        .setDescription(`${interaction.user}, כתוב כאן את הדיווח שלך. הצוות יענה בהקדם.`)
        .addFields({ name: "סטטוס", value: "ממתין לצוות" })
        .setTimestamp();

      await ticketChannel.send({
        content: `${interaction.user}`,
        embeds: [embed],
        components: [buildTicketActionRow()],
      });
      await interaction.editReply({ content: `פתחתי לך טיקט: ${ticketChannel}` });
      return;
    }

    if (interaction.isButton() && interaction.customId === TICKET_CLAIM_BUTTON_ID) {
      if (!isStaff(interaction.member)) {
        await replyPrivately(interaction, "רק חבר צוות יכול לקחת טיקט.");
        return;
      }

      if (ticketClaimLocks.has(interaction.channelId)) {
        await replyPrivately(interaction, "מישהו כבר לוקח את הטיקט הזה.");
        return;
      }

      const ticketOwnerId = getTicketOwnerId(interaction.channel);
      if (!ticketOwnerId) {
        await replyPrivately(interaction, "לא הצלחתי לזהות מי פתח את הטיקט.");
        return;
      }

      ticketClaimLocks.add(interaction.channelId);
      try {
        await interaction.deferUpdate();
        const validStaffRoleIds = STAFF_ROLE_IDS.filter((roleId) => (
          interaction.guild.roles.cache.has(roleId)
        ));
        const overwriteResults = await Promise.allSettled([
          ...validStaffRoleIds.map((roleId) => interaction.channel.permissionOverwrites.edit(roleId, {
            ViewChannel: false,
          })),
          interaction.channel.permissionOverwrites.edit(ticketOwnerId, {
            ViewChannel: true,
            SendMessages: true,
            ReadMessageHistory: true,
          }),
          interaction.channel.permissionOverwrites.edit(interaction.user.id, {
            ViewChannel: true,
            SendMessages: true,
            ReadMessageHistory: true,
          }),
        ]);

        const failedOverwrite = overwriteResults.find((result) => result.status === "rejected");
        if (failedOverwrite) throw failedOverwrite.reason;

        const oldEmbed = interaction.message.embeds[0];
        const embed = EmbedBuilder.from(oldEmbed ?? new EmbedBuilder())
          .setColor(0x2ecc71)
          .setFields({ name: "סטטוס", value: `בטיפול של ${interaction.user}` })
          .setTimestamp();

        await interaction.message.edit({
          embeds: [embed],
          components: [buildTicketActionRow({ claimedBy: interaction.user.username })],
        });
        await interaction.channel.send(
          `הטיקט נלקח על ידי ${interaction.user}. מעכשיו רק ${interaction.user} ו־<@${ticketOwnerId}> יכולים לראות אותו.`,
        );
      } catch (error) {
        console.error("Could not claim ticket:", error);
        await replyPrivately(interaction, "לא הצלחתי לקחת את הטיקט. ייתכן שהערוץ נמחק או שחסרה הרשאת ניהול ערוצים.");
      } finally {
        ticketClaimLocks.delete(interaction.channelId);
      }
      return;
    }

    if (interaction.isButton() && interaction.customId === TICKET_CLOSE_BUTTON_ID) {
      const ticketOwnerId = getTicketOwnerId(interaction.channel);
      const isTicketOwner = ticketOwnerId === interaction.user.id;
      if (!isTicketOwner && !isStaff(interaction.member)) {
        await replyPrivately(interaction, "רק פותח הטיקט או חבר צוות יכולים לסגור אותו.");
        return;
      }

      await interaction.reply("הטיקט ייסגר בעוד 5 שניות.");
      setTimeout(async () => {
        await interaction.channel.delete("Ticket closed").catch(console.error);
      }, 5000);
      return;
    }

    if (interaction.isButton() && interaction.customId === HELP_CLAIM_BUTTON_ID) {
      if (!isStaff(interaction.member)) {
        await replyPrivately(interaction, "רק חבר צוות יכול לקחת את הפנייה הזאת.");
        return;
      }

      const oldEmbed = interaction.message.embeds[0];
      const voiceField = oldEmbed?.fields?.find((field) => field.name === "שיחת קול");
      const requestChannelField = oldEmbed?.fields?.find((field) => field.name === "חדר בקשה");
      const embed = EmbedBuilder.from(oldEmbed ?? new EmbedBuilder())
        .setColor(0x2ecc71)
        .setFields(
          { name: "סטטוס", value: `בטיפול של ${interaction.user}` },
          { name: "שיחת קול", value: voiceField?.value ?? "לא ידוע" },
          { name: "חדר בקשה", value: requestChannelField?.value ?? `${interaction.channel}` },
        )
        .setTimestamp();

      const row = new ActionRowBuilder().addComponents(
        new ButtonBuilder()
          .setCustomId(HELP_CLAIM_BUTTON_ID)
          .setLabel(`נלקח על ידי ${interaction.user.username}`)
          .setStyle(ButtonStyle.Success)
          .setDisabled(true),
      );

      await interaction.update({ embeds: [embed], components: [row] });
      return;
    }

    if (!interaction.isButton() || interaction.customId !== VERIFY_BUTTON_ID) return;

    if (!VERIFIED_ROLE_ID) {
      await replyPrivately(interaction, "תפקיד האימות עדיין לא הוגדר.");
      return;
    }

    const role = await interaction.guild.roles.fetch(VERIFIED_ROLE_ID).catch(() => null);
    if (!role) {
      await replyPrivately(interaction, "לא מצאתי את תפקיד האימות שהוגדר.");
      return;
    }

    if (interaction.member.roles.cache.has(role.id)) {
      await replyPrivately(interaction, "אתה כבר מאומת.");
      return;
    }

    try {
      await interaction.member.roles.add(role);
      await replyPrivately(interaction, "האימות הושלם. ברוך הבא!");
    } catch (error) {
      console.error("Could not add verification role:", error);
      await replyPrivately(
        interaction,
        "לא הצלחתי להוסיף את התפקיד. צריך לוודא שלבוט יש Manage Roles ושהתפקיד שלו נמצא מעל תפקיד האימות.",
      );
    }
  } catch (error) {
    console.error("Interaction handler failed:", error);
    await replyPrivately(interaction, "אירעה שגיאה בזמן ביצוע הפעולה.");
  }
});

client.login(DISCORD_TOKEN);
